# Also used by the TypeORM migration CLI (yarn migration:run, etc.) via dotenv
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=vehicle-service-manager
REQUIRE_SSL=false

JWT_SECRET=

# E2E test credentials (seeded user — must exist in the database)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_USER_FIRST_NAME=
E2E_USER_LAST_NAME=
